# Copia questo file in .env e compila i valori

# ID progetto GCP
VERTEX_PROJECT_ID=eastern-map-380616

# Regione Vertex AI — Live native-audio disponibile in UE: europe-west1 (Belgio) o europe-west4 (Olanda)
VERTEX_LOCATION=europe-west1

# Modello Live native-audio (unico che apre la sessione)
VERTEX_MODEL=gemini-live-2.5-flash-native-audio

# Porta proxy (in locale 3001; su Render/host la imposta la piattaforma)
PORT=3001

# AUTH — due modi:
# 1) LOCALE: ADC (gcloud auth application-default login) -> lascia GOOGLE_SA_JSON vuoto
# 2) DEPLOY (Render/host): incolla il contenuto JSON del service account su UNA riga
# GOOGLE_SA_JSON={"type":"service_account","project_id":"...",...}
